{
    "name": "auth-service",
    "version": "1.0.0",
    "description": "A User Managment Servive",
    "main": "index.js",
    "author": "Anas Sain",
    "license": "ISC",
    "scripts": {
        "format:check": "npx prettier . --check",
        "format:fix": "npx prettier . --write",
